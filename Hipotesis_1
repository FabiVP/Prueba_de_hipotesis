        "# ============================================================\n",
        "# PRUEBA DE HIPÓTESIS — INGENIERÍA DE SISTEMAS\n",
        "# Script completo para Google Colab / Jupyter Notebook\n",
        "# Autor: Análisis Estadístico Aplicado\n",
        "# ============================================================\n",
        "# INSTRUCCIONES COLAB:\n",
        "# 1. Subir los archivos .xlsx al entorno de Colab\n",
        "# 2. Ajustar las rutas en la sección \"Cargar Datos\"\n",
        "# 3. Ejecutar todas las celdas en orden\n",
        "# ============================================================\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.gridspec as gridspec\n",
        "from scipy import stats\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# ── Paleta de colores profesional ──────────────────────────\n",
        "C1 = '#2E86AB'   # Azul\n",
        "C2 = '#E84855'   # Rojo\n",
        "C3 = '#3BB273'   # Verde\n",
        "C4 = '#F4A261'   # Naranja\n",
        "C5 = '#7B2D8B'   # Morado\n",
        "\n",
        "plt.rcParams.update({\n",
        "    'font.family': 'DejaVu Sans',\n",
        "    'axes.spines.top': False,\n",
        "    'axes.spines.right': False,\n",
        "    'figure.facecolor': 'white',\n",
        "    'axes.facecolor': '#F5F5F5',\n",
        "    'axes.grid': True,\n",
        "    'grid.color': 'white',\n",
        "    'grid.linewidth': 1.2\n",
        "})\n",
        "\n",
        "# ============================================================\n",
        "# CARGA DE DATOS\n",
        "# ── Ajustar rutas según entorno ──────────────────────────\n",
        "# ============================================================\n",
        "# En Google Colab: subir archivos y usar solo el nombre\n",
        "# Ejemplo:  pd.read_excel('tstudent_algoritmos.xlsx')\n",
        "\n",
        "from google.colab import files\n",
        "import io\n",
        "\n",
        "print(\"📂 Sube el archivo: tstudent_algoritmos.xlsx\")\n",
        "uploaded = files.upload()\n",
        "df1 = pd.read_excel(io.BytesIO(list(uploaded.values())[0]))\n",
        "# ============================================================\n",
        "# ╔══════════════════════════════════════════════════════╗\n",
        "# ║  HIPÓTESIS 1 — t-Student (Cola Superior)             ║\n",
        "# ║  H0: μA ≤ μB   |   H1: μA > μB                      ║\n",
        "# ║  Dataset: tstudent_algoritmos.xlsx                   ║\n",
        "# ╚══════════════════════════════════════════════════════╝\n",
        "# ============================================================\n",
        "\n",
        "A = df1['Algoritmo_A_ops_sec']\n",
        "B = df1['Algoritmo_B_ops_sec']\n",
        "\n",
        "print(\"=\" * 65)\n",
        "print(\"HIPÓTESIS 1: t-Student Independiente (Cola Superior)\")\n",
        "print(\"=\" * 65)\n",
        "\n",
        "# ── PASO 1: Estadísticas descriptivas ──\n",
        "print(\"\\n📊 ESTADÍSTICAS DESCRIPTIVAS\")\n",
        "print(f\"{'':25s} {'Algoritmo A':>15s} {'Algoritmo B':>15s}\")\n",
        "print(f\"{'Media':25s} {A.mean():>15.4f} {B.mean():>15.4f}\")\n",
        "print(f\"{'Mediana':25s} {A.median():>15.4f} {B.median():>15.4f}\")\n",
        "print(f\"{'Desviación estándar':25s} {A.std():>15.4f} {B.std():>15.4f}\")\n",
        "print(f\"{'Mínimo':25s} {A.min():>15.4f} {B.min():>15.4f}\")\n",
        "print(f\"{'Máximo':25s} {A.max():>15.4f} {B.max():>15.4f}\")\n",
        "print(f\"{'n':25s} {len(A):>15d} {len(B):>15d}\")\n",
        "\n",
        "# ── PASO 3: Verificación de supuestos ──\n",
        "print(\"\\n✅ VERIFICACIÓN DE SUPUESTOS\")\n",
        "sw_A = stats.shapiro(A)\n",
        "sw_B = stats.shapiro(B)\n",
        "lev1 = stats.levene(A, B)\n",
        "print(f\"Shapiro-Wilk A:  W = {sw_A.statistic:.4f}, p = {sw_A.pvalue:.4f} \"\n",
        "      f\"→ {'Normal ✓' if sw_A.pvalue > 0.05 else 'No normal ✗'}\")\n",
        "print(f\"Shapiro-Wilk B:  W = {sw_B.statistic:.4f}, p = {sw_B.pvalue:.4f} \"\n",
        "      f\"→ {'Normal ✓' if sw_B.pvalue > 0.05 else 'No normal ✗'}\")\n",
        "print(f\"Levene:          F = {lev1.statistic:.4f}, p = {lev1.pvalue:.4f} \"\n",
        "      f\"→ {'Varianzas iguales ✓' if lev1.pvalue > 0.05 else 'Varianzas desiguales'}\")\n",
        "\n",
        "# ── PASO 4: Prueba t-Student ──\n",
        "print(\"\\n🔬 APLICACIÓN DE PRUEBA\")\n",
        "t_stat, p_h1 = stats.ttest_ind(A, B, equal_var=True, alternative='greater')\n",
        "print(f\"t estadístico:         {t_stat:.4f}\")\n",
        "print(f\"Valor p (cola sup.):   {p_h1:.8f}\")\n",
        "print(f\"Nivel de sign. (α):    0.05\")\n",
        "print(f\"\\n📌 DECISIÓN: {'✅ RECHAZAR H0 — μA > μB confirmado' if p_h1 < 0.05 else '❌ NO rechazar H0'}\")\n",
        "print(f\"\\n💡 INTERPRETACIÓN:\")\n",
        "print(f\"   El Algoritmo A (μ={A.mean():.2f} ops/seg) es significativamente\")\n",
        "print(f\"   más rápido que el Algoritmo B (μ={B.mean():.2f} ops/seg),\")\n",
        "print(f\"   con un valor p < 0.001, lo que proporciona evidencia\")\n",
        "print(f\"   estadística muy fuerte para rechazar H0.\")\n",
        "\n",
        "# ── PASO 1: Gráficos H1 ──\n",
        "fig1, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
        "fig1.suptitle('H1: t-Student — Rendimiento de Algoritmos (ops/seg)',\n",
        "              fontsize=13, fontweight='bold')\n",
        "\n",
        "axes[0].hist(A, bins=20, color=C1, alpha=0.8, edgecolor='white', label='Algoritmo A')\n",
        "axes[0].axvline(A.mean(), color='navy', lw=2, ls='--', label=f'μ={A.mean():.1f}')\n",
        "axes[0].set_title('Histograma — Algoritmo A'); axes[0].set_xlabel('ops/seg')\n",
        "axes[0].set_ylabel('Frecuencia'); axes[0].legend()\n",
        "\n",
        "axes[1].hist(B, bins=20, color=C2, alpha=0.8, edgecolor='white', label='Algoritmo B')\n",
        "axes[1].axvline(B.mean(), color='darkred', lw=2, ls='--', label=f'μ={B.mean():.1f}')\n",
        "axes[1].set_title('Histograma — Algoritmo B'); axes[1].set_xlabel('ops/seg')\n",
        "axes[1].set_ylabel('Frecuencia'); axes[1].legend()\n",
        "\n",
        "bp = axes[2].boxplot([A, B], labels=['Algoritmo A', 'Algoritmo B'],\n",
        "                     patch_artist=True, notch=True,\n",
        "                     medianprops=dict(color='black', lw=2))\n",
        "for box, color in zip(bp['boxes'], [C1, C2]):\n",
        "    box.set_facecolor(color); box.set_alpha(0.75)\n",
        "axes[2].set_title('Boxplot Comparativo'); axes[2].set_ylabel('ops/seg')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('H1_tstudent.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "# ============================================================\n",
        "# RESUMEN EJECUTIVO\n",
        "# ============================================================\n",
        "print(\"\\n\" + \"=\" * 65)\n",
        "print(\"RESUMEN EJECUTIVO — HIPÓTESIS 1\")\n",
        "print(\"=\" * 65)\n",
        "\n",
        "print(f\"{'Hipótesis':<12s} {'Prueba':<20s} {'Estadístico':<18s} {'p-valor':<14s} {'Decisión'}\")\n",
        "print(\"-\" * 65)\n",
        "\n",
        "print(f\"{'H1':<12s} {'t-Student':<20s} {f't={t_stat:.2f}':<18s} {p_h1:<14.6f} \"\n",
        "      f\"{'Rechazar H0 ✅' if p_h1 < 0.05 else 'No rechazar H0 ❌'}\")\n",
        "\n",
        "print(\"=\" * 65)\n",
        "print(f\"α = 0.05  |  n = {len(A)}\")"
      ]
    }
